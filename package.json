{
  "name": "mqtt-line-chart",
  "version": "1.0.0",
  "description": "MQTT JSON Line Chart Dashboard - Real-time data visualization desktop tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --config"
  },
  "build": {
    "appId": "com.mqtt-line-chart.app",
    "productName": "MQTT Line Chart",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "keywords": ["mqtt", "chart", "dashboard", "realtime", "electron"],
  "license": "MIT",
  "dependencies": {
    "mqtt": "^5.10.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
